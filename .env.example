AUTH_MODE=google
GOOGLE_CLIENT_ID=
GOOGLE_ALLOWED_DOMAINS=

# Docker host binding. Use HOST_PORT=8011 on a shared server if 8000 is taken.
HOST_BIND=127.0.0.1
HOST_PORT=8000

# Optional username/password login (works alongside Google/development).
# Leave blank to disable the password form.
AUTH_USERNAME=
AUTH_PASSWORD=

# Optional static API key for machine/Swagger access via the X-API-Key header.
API_KEY=

# Generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-at-least-32-random-characters
SESSION_SECURE=false

ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_v3
ELEVENLABS_LANGUAGE_CODE=en
HUGGINGFACE_TOKEN=
OMNIVOICE_BASE_URL=https://salmanbvps-omnivoice-batch-tts.hf.space
OMNIVOICE_TIMEOUT_SECONDS=240
# Rows per OmniVoice /batch call (true batched inference). Keep modest so one
# ZeroGPU request stays within its time budget.
OMNIVOICE_BATCH_CHUNK=6

# OmniVoice text conversion uses OpenRouter through the backend. Reasoning is
# not requested or logged.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_MAX_TOKENS=5000
OPENROUTER_TIMEOUT_SECONDS=120

DATA_DIR=/app/data
STATIC_DIR=/app/frontend_dist

# Generation guardrails.
# Max parallel TTS+ffmpeg jobs. Keep <= your ElevenLabs plan concurrency limit
# (Free 2, Starter 3, Creator 5, Pro 10, Scale/Business 15) to avoid 429s.
MAX_CONCURRENT_GENERATIONS=2
# Max rows accepted in one batch upload (protects cost/time).
MAX_BATCH_ROWS=200
